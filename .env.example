# ===== Google OAuth (см. README, раздел «Google OAuth») =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== NextAuth =====
# Сгенерируйте: openssl rand -base64 32
NEXTAUTH_SECRET=
# Локально: http://localhost:3000  ·  На Vercel: https://ваш-домен.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Доступ только для вас (можно несколько через запятую)
ALLOWED_EMAILS=your.email@gmail.com

# ===== Supabase (Settings → API) =====
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Obsidian-first =====
# ID папки Inbox вашего Obsidian Vault в Google Drive
# (откройте папку в Drive — ID в адресной строке после /folders/)
OBSIDIAN_INBOX_FOLDER_ID=

# ===== Second Brain — доменные папки в Drive =====
# Создайте папки SecondBrain/HR Trends, /Content Ideas, /Career в Vault и вставьте их ID.
# Если не заданы — проекция в Drive просто пропускается (Supabase продолжает работать).
SB_HR_TRENDS_FOLDER_ID=
SB_CONTENT_FOLDER_ID=
SB_CAREER_FOLDER_ID=

# ===== File Upload Center =====
# Папка «Personal OS Uploads» в Google Drive — куда уходят загруженные файлы.
UPLOADS_FOLDER_ID=

# ===== Telegram (исходящие черновики постов) =====
# Бот от @BotFather; chat id — ваш личный (узнать через @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Автозапуск агентов (Vercel Cron) =====
# Секрет для защиты cron-роутов /api/cron/[agent].
AGENT_CRON_SECRET=
# Vercel Cron сам шлёт Authorization: Bearer ${CRON_SECRET} — задайте CRON_SECRET
# тем же значением, что и AGENT_CRON_SECRET, чтобы автозапуск проходил проверку.
CRON_SECRET=
