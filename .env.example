# ===== Google OAuth (см. README, раздел «Google OAuth») =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== NextAuth =====
# Сгенерируйте: openssl rand -base64 32
NEXTAUTH_SECRET=
# Локально: http://localhost:3000  ·  На Vercel: https://ваш-домен.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Доступ только для вас (можно несколько через запятую)
ALLOWED_EMAILS=your.email@gmail.com

# ===== Supabase (Settings → API) =====
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Obsidian-first =====
# ID папки Inbox вашего Obsidian Vault в Google Drive
# (откройте папку в Drive — ID в адресной строке после /folders/)
OBSIDIAN_INBOX_FOLDER_ID=
